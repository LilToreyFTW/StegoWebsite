{
  "version": 2,
  "name": "stegoproxy-license-api",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/validate-license",
      "dest": "/api/validate-license.js"
    },
    {
      "src": "/api/check-license",
      "dest": "/api/validate-license.js"
    },
    {
      "src": "/api/revoke-license",
      "dest": "/api/validate-license.js"
    },
    {
      "src": "/api/license-stats",
      "dest": "/api/validate-license.js"
    },
    {
      "src": "/api/beacon",
      "dest": "/api/beacon.js"
    },
    {
      "src": "/api/beacon-events",
      "dest": "/api/beacon.js"
    },
    {
      "src": "/api/beacon-stats",
      "dest": "/api/beacon.js"
    }
  ]
}
